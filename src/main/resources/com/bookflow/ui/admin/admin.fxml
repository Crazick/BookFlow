<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bookflow.ui.admin.AdminController">

    <!-- GÓRA -->
    <top>
        <Label text="Panel administratora"
               style="-fx-font-size: 24px;
                      -fx-font-weight: bold;
                      -fx-padding: 10;"/>
    </top>

    <!-- ŚRODEK -->
    <center>

        <HBox spacing="15" style="-fx-padding: 10;">

            <!-- LEWY PANEL - FORMULARZ -->
            <VBox spacing="10" prefWidth="500">

                <TextField fx:id="idField" promptText="ID książki"/>
                <TextField fx:id="titleField" promptText="Tytuł"/>
                <TextField fx:id="authorField" promptText="Autor"/>
                <TextField fx:id="genreField" promptText="Gatunek"/>
                <TextField fx:id="totalCopiesField" promptText="Liczba egzemplarzy"/>
                <TextField fx:id="availableCopiesField" promptText="Dostępne egzemplarze"/>

                <!-- PRZYCISKI W JEDNEJ LINII -->
                <HBox spacing="10">

                    <Button text="Dodaj" onAction="#handleAdd"/>
                    <Button text="Aktualizuj" onAction="#handleUpdate"/>
                    <Button text="Usuń" onAction="#handleDelete"/>
                    <Button text="Wczytaj" onAction="#handleLoad"/>

                </HBox>
                <!-- WYLOGUJ -->
                <Button text="Wyloguj" onAction="#handleLogout"/>

                <Label fx:id="statusLabel"/>

            </VBox>

            <!-- PRAWA STRONA - TABELA -->
            <TableView fx:id="booksTable"
                       prefWidth="850"
                       prefHeight="600">

                <columns>

                    <TableColumn fx:id="idColumn"
                                 text="ID"
                                 prefWidth="60"
                                 resizable="false"/>

                    <TableColumn fx:id="titleColumn"
                                 text="Tytuł"
                                 prefWidth="250"
                                 resizable="false"/>

                    <TableColumn fx:id="authorColumn"
                                 text="Autor"
                                 prefWidth="200"
                                 resizable="false"/>

                    <TableColumn fx:id="genreColumn"
                                 text="Gatunek"
                                 prefWidth="150"
                                 resizable="false"/>

                    <TableColumn fx:id="totalColumn"
                                 text="Wszystkie"
                                 prefWidth="90"
                                 resizable="false"/>

                    <TableColumn fx:id="availableColumn"
                                 text="Dostępne"
                                 prefWidth="90"
                                 resizable="false"/>

                </columns>

            </TableView>

        </HBox>

    </center>

</BorderPane>
